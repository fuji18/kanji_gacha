{
  // ビルド時データ生成スクリプト用（repository-structure 2.5）。
  // scripts/ は Vite 本体の tsconfig.json（include:["src"]）の対象外のため、
  // ここで scripts/ ＋ src/domain を解決対象にし、tsx 実行や型検査に使う。
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext"],
    "types": ["node"],
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true
  },
  "include": ["scripts", "src/domain"]
}
