{
  "name": "kanji_gacha",
  "version": "0.0.0",
  "description": "漢字合体ガチャ（仮称） — Vite + Svelte 5 + TypeScript の静的Webアプリ",
  "type": "module",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "test:e2e": "playwright test",
    "gen:assets": "node scripts/gen-assets.mjs",
    "gen:data": "tsx --tsconfig tsconfig.scripts.json scripts/build-data/generate.ts",
    "verify:data": "tsx --tsconfig tsconfig.scripts.json scripts/build-data/verify.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,svelte}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,json,css,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@playwright/test": "^1.61.1",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@types/node": "^22.8.0",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-svelte": "^3.20.0",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "prettier-plugin-svelte": "^4.1.1",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.2",
    "tslib": "^2.8.0",
    "tsx": "^4.23.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.63.0",
    "vite": "^5.4.0",
    "vite-plugin-pwa": "^0.20.5",
    "vitest": "^2.1.0"
  }
}
